POSTGRES_DB=chat_prod
POSTGRES_USER=chat_prod
POSTGRES_PASSWORD=chat_prod
API_PORT=3000
APP_NAME=production-chat-api
# Redis is mandatory for backend startup and realtime coordination in the deployed stack.
JWT_ACCESS_SECRET=replace-with-production-access-secret
JWT_REFRESH_SECRET=replace-with-production-refresh-secret
# 生产栈必须接入外部验证码服务；后端会 POST identifier/purpose/code/expiresInSeconds 到该地址。
AUTH_CODE_WEBHOOK_URL=https://code-provider.example.com/send
# 可选：验证码 webhook 鉴权密钥，后端会使用 Authorization: Bearer <secret>。
AUTH_CODE_WEBHOOK_SECRET=replace-with-production-code-webhook-secret
# 必填：发件邮箱账号，传给验证码 webhook 的 sender.email。
AUTH_CODE_EMAIL_FROM=no-reply@example.com
# 必填：发件人展示昵称，传给验证码 webhook 的 sender.nickname。
AUTH_CODE_EMAIL_NICKNAME=Production Chat
# 必填：发件人 handle/标识，传给验证码 webhook 的 sender.handle。
AUTH_CODE_EMAIL_HANDLE=production_chat
S3_BUCKET=chat-production
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
