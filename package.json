{
  "name": "production-chat-app-workspace",
  "private": true,
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "analyze:mobile": "cd mobile && flutter analyze",
    "db:up": "docker compose -f docker/compose.infra.yml up -d",
    "db:down": "docker compose -f docker/compose.infra.yml down",
    "db:logs": "docker compose -f docker/compose.infra.yml logs -f",
    "dev:db": "pnpm db:up",
    "dev:prepare": "pnpm db:up && pnpm server:migrate:dev",
    "dev:server": "pnpm --dir server start:dev",
    "dev:web": "cd mobile && flutter run -d chrome --dart-define-from-file=config/env/development.json.example",
    "dev:web:test": "cd mobile && flutter run -d chrome --dart-define-from-file=config/env/test.json.example",
    "dev:web:staging": "cd mobile && flutter run -d chrome --dart-define-from-file=config/env/staging.json.example",
    "dev:web:prod": "cd mobile && flutter run -d chrome --dart-define-from-file=config/env/production.json.example",
    "docker-local:prepare": "pnpm db:up && pnpm server:migrate:docker-local",
    "docker-local:server": "pnpm --dir server start:dev:docker-local",
    "infra:dev:up": "docker compose -f docker/compose.infra.yml up -d",
    "infra:dev:down": "docker compose -f docker/compose.infra.yml down",
    "infra:dev:logs": "docker compose -f docker/compose.infra.yml logs -f",
    "test:mobile": "cd mobile && flutter test",
    "infra:up": "docker compose -f docker/compose.infra.yml up -d",
    "infra:down": "docker compose -f docker/compose.infra.yml down",
    "infra:logs": "docker compose -f docker/compose.infra.yml logs -f",
    "lint:server": "pnpm --dir server lint",
    "server:build": "pnpm --dir server build",
    "server:dev": "pnpm --dir server start:dev",
    "server:docker-local": "pnpm --dir server start:dev:docker-local",
    "server:generate": "pnpm --dir server prisma:generate",
    "server:migrate:dev": "pnpm --dir server prisma:migrate:dev",
    "server:migrate:docker-local": "pnpm --dir server prisma:migrate:dev:docker-local",
    "server:test": "pnpm --dir server test",
    "server:test:contract": "pnpm --dir server test:contract",
    "server:test:integration": "pnpm --dir server test:integration",
    "server:typecheck": "pnpm --dir server typecheck",
    "dev:server:docker-local": "pnpm --dir server start:dev:docker-local",
    "migrate:server:docker-local": "pnpm --dir server prisma:migrate:dev:docker-local",
    "stack:up": "docker compose -f docker/compose.stack.yml up -d --build",
    "stack:down": "docker compose -f docker/compose.stack.yml down",
    "stack:logs": "docker compose -f docker/compose.stack.yml logs -f",
    "test:server:contract": "pnpm --dir server test:contract",
    "test:server:integration": "pnpm --dir server test:integration",
    "test:server": "pnpm --dir server test",
    "typecheck:server": "pnpm --dir server typecheck"
  }
}
