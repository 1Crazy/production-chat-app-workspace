NODE_ENV=development
PORT=3000
APP_NAME=production-chat-api
DATABASE_URL=postgres://chat_dev:chat_dev@localhost:5432/chat_dev
# Required: realtime, presence, idempotency, and Socket.IO multi-instance coordination all depend on Redis.
REDIS_URL=redis://localhost:6379/0
JWT_ACCESS_SECRET=replace-with-dev-access-secret
JWT_REFRESH_SECRET=replace-with-dev-refresh-secret
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=chat-dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
# Optional: enables real FCM HTTP v1 push delivery instead of log-only fallback.
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
ADMIN_HANDLES=
