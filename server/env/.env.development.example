NODE_ENV=development
PORT=3000
APP_NAME=production-chat-api
# CORS 域名白名单，逗号分隔。生产环境必须显式填写具体域名，否则跨域请求会被拒绝。
CORS_ALLOWED_ORIGINS=*
DATABASE_URL=postgres://chat_dev:chat_dev@localhost:55432/chat_dev
# 必填：实时连接、在线状态、幂等控制以及 Socket.IO 多实例协同都依赖 Redis。
REDIS_URL=redis://localhost:6379/0
JWT_ACCESS_SECRET=replace-with-dev-access-secret
JWT_REFRESH_SECRET=replace-with-dev-refresh-secret
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=chat-dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
# 可选：填写后会启用真实的 FCM HTTP v1 推送；不填写时默认只走日志降级链路。
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
ADMIN_HANDLES=
# 验证码投递模式。debug=只写入数据库并允许接口返回 debugCode；webhook=调用外部短信/邮件服务。
AUTH_CODE_DELIVERY_MODE=debug
# 是否在 /auth/request-code 响应里返回 debugCode。仅开发/测试可开，生产环境启动时会强制禁止。
AUTH_DEBUG_CODE_ENABLED=true
# 当 AUTH_CODE_DELIVERY_MODE=webhook 时必填：外部验证码服务接收地址，服务会 POST identifier/purpose/code/expiresInSeconds。
AUTH_CODE_WEBHOOK_URL=
# 当 webhook 需要鉴权时填写：后端会用 Authorization: Bearer <secret> 调用上面的地址。
AUTH_CODE_WEBHOOK_SECRET=
# 发件邮箱账号。开发 debug 模式可留空；webhook 模式会放进 sender.email。
AUTH_CODE_EMAIL_FROM=
# 发件人展示昵称。开发 debug 模式可留空；webhook 模式会放进 sender.nickname。
AUTH_CODE_EMAIL_NICKNAME=
# 发件人 handle/标识。开发 debug 模式可留空；webhook 模式会放进 sender.handle。
AUTH_CODE_EMAIL_HANDLE=
# 是否启用注册/登录/验证码/重置密码限流。开发环境建议关闭，方便反复调试登录与登出。
AUTH_RATE_LIMIT_ENABLED=false
# 鉴权限流统计窗口，单位分钟。下面各类次数限制都基于这个时间窗口计算。
AUTH_RATE_LIMIT_WINDOW_MINUTES=10
# 验证码请求：同一来源（如 IP）在窗口期内最多可请求的次数。
AUTH_REQUEST_CODE_SOURCE_LIMIT=6
# 验证码请求：同一账号标识在窗口期内最多可请求的次数。
AUTH_REQUEST_CODE_IDENTIFIER_LIMIT=3
# 注册：同一来源在窗口期内最多可尝试的次数。
AUTH_REGISTER_SOURCE_LIMIT=5
# 注册：同一账号标识在窗口期内最多可尝试的次数。
AUTH_REGISTER_IDENTIFIER_LIMIT=3
# 登录：同一来源在窗口期内最多可尝试的次数。
AUTH_LOGIN_SOURCE_LIMIT=10
# 登录：同一账号标识在窗口期内最多可尝试的次数。
AUTH_LOGIN_IDENTIFIER_LIMIT=5
# 重置密码：同一来源在窗口期内最多可尝试的次数。
AUTH_RESET_PASSWORD_SOURCE_LIMIT=5
# 重置密码：同一账号标识在窗口期内最多可尝试的次数。
AUTH_RESET_PASSWORD_IDENTIFIER_LIMIT=3
