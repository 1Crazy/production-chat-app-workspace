NODE_ENV=test
PORT=3001
APP_NAME=production-chat-api-test
# CORS 域名白名单，测试环境允许通配符，避免自动化用例依赖固定端口。
CORS_ALLOWED_ORIGINS=*
DATABASE_URL=postgres://chat_test:chat_test@localhost:5432/chat_test
REDIS_URL=redis://localhost:6379/1
JWT_ACCESS_SECRET=replace-with-test-access-secret
JWT_REFRESH_SECRET=replace-with-test-refresh-secret
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=chat-test
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
ADMIN_HANDLES=
# 验证码投递模式。测试环境使用 debug，避免自动化测试依赖外部短信/邮件服务。
AUTH_CODE_DELIVERY_MODE=debug
# 是否在 /auth/request-code 响应里返回 debugCode。测试环境开启，方便测试用例直接完成注册/重置密码。
AUTH_DEBUG_CODE_ENABLED=true
# 当 AUTH_CODE_DELIVERY_MODE=webhook 时必填：外部验证码服务接收地址。
AUTH_CODE_WEBHOOK_URL=
# 当 webhook 需要鉴权时填写：后端会用 Authorization: Bearer <secret> 调用上面的地址。
AUTH_CODE_WEBHOOK_SECRET=
# 发件邮箱账号。测试 debug 模式可留空；webhook 模式会放进 sender.email。
AUTH_CODE_EMAIL_FROM=
# 发件人展示昵称。测试 debug 模式可留空；webhook 模式会放进 sender.nickname。
AUTH_CODE_EMAIL_NICKNAME=
# 发件人 handle/标识。测试 debug 模式可留空；webhook 模式会放进 sender.handle。
AUTH_CODE_EMAIL_HANDLE=
# 是否启用注册/登录/验证码/重置密码限流。测试环境通常建议关闭，避免影响自动化测试稳定性。
AUTH_RATE_LIMIT_ENABLED=false
# 鉴权限流统计窗口，单位分钟。下面各类次数限制都基于这个时间窗口计算。
AUTH_RATE_LIMIT_WINDOW_MINUTES=10
# 验证码请求：同一来源（如 IP）在窗口期内最多可请求的次数。
AUTH_REQUEST_CODE_SOURCE_LIMIT=6
# 验证码请求：同一账号标识在窗口期内最多可请求的次数。
AUTH_REQUEST_CODE_IDENTIFIER_LIMIT=3
# 注册：同一来源在窗口期内最多可尝试的次数。
AUTH_REGISTER_SOURCE_LIMIT=5
# 注册：同一账号标识在窗口期内最多可尝试的次数。
AUTH_REGISTER_IDENTIFIER_LIMIT=3
# 登录：同一来源在窗口期内最多可尝试的次数。
AUTH_LOGIN_SOURCE_LIMIT=10
# 登录：同一账号标识在窗口期内最多可尝试的次数。
AUTH_LOGIN_IDENTIFIER_LIMIT=5
# 重置密码：同一来源在窗口期内最多可尝试的次数。
AUTH_RESET_PASSWORD_SOURCE_LIMIT=5
# 重置密码：同一账号标识在窗口期内最多可尝试的次数。
AUTH_RESET_PASSWORD_IDENTIFIER_LIMIT=3
