NODE_ENV=staging
PORT=3000
APP_NAME=production-chat-api-staging
DATABASE_URL=postgres://chat_staging:chat_staging@staging-db:5432/chat_staging
REDIS_URL=redis://staging-redis:6379/0
JWT_ACCESS_SECRET=replace-with-staging-access-secret
JWT_REFRESH_SECRET=replace-with-staging-refresh-secret
S3_ENDPOINT=https://staging-object-storage.example.com
S3_BUCKET=chat-staging
S3_ACCESS_KEY=replace-with-staging-key
S3_SECRET_KEY=replace-with-staging-secret
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
ADMIN_HANDLES=
