NODE_ENV=production
PORT=3000
APP_NAME=production-chat-api
DATABASE_URL=postgres://chat_prod:replace-with-prod-password@prod-db:5432/chat_prod
REDIS_URL=redis://prod-redis:6379/0
JWT_ACCESS_SECRET=replace-with-production-access-secret
JWT_REFRESH_SECRET=replace-with-production-refresh-secret
S3_ENDPOINT=https://object-storage.example.com
S3_BUCKET=chat-production
S3_ACCESS_KEY=replace-with-production-key
S3_SECRET_KEY=replace-with-production-secret
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
ADMIN_HANDLES=
# 是否启用注册/登录/验证码/重置密码限流。生产环境建议开启。
AUTH_RATE_LIMIT_ENABLED=true
# 鉴权限流统计窗口，单位分钟。下面各类次数限制都基于这个时间窗口计算。
AUTH_RATE_LIMIT_WINDOW_MINUTES=10
# 验证码请求：同一来源（如 IP）在窗口期内最多可请求的次数。
AUTH_REQUEST_CODE_SOURCE_LIMIT=6
# 验证码请求：同一账号标识在窗口期内最多可请求的次数。
AUTH_REQUEST_CODE_IDENTIFIER_LIMIT=3
# 注册：同一来源在窗口期内最多可尝试的次数。
AUTH_REGISTER_SOURCE_LIMIT=5
# 注册：同一账号标识在窗口期内最多可尝试的次数。
AUTH_REGISTER_IDENTIFIER_LIMIT=3
# 登录：同一来源在窗口期内最多可尝试的次数。
AUTH_LOGIN_SOURCE_LIMIT=10
# 登录：同一账号标识在窗口期内最多可尝试的次数。
AUTH_LOGIN_IDENTIFIER_LIMIT=5
# 重置密码：同一来源在窗口期内最多可尝试的次数。
AUTH_RESET_PASSWORD_SOURCE_LIMIT=5
# 重置密码：同一账号标识在窗口期内最多可尝试的次数。
AUTH_RESET_PASSWORD_IDENTIFIER_LIMIT=3
