generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String              @id @default(uuid())
  identifier        String              @unique
  nickname          String
  handle            String              @unique
  passwordHash      String?             @map("password_hash")
  passwordUpdatedAt DateTime?           @map("password_updated_at")
  friendRequestLastViewedAt DateTime?   @map("friend_request_last_viewed_at")
  avatarUrl         String?             @map("avatar_url")
  discoveryMode     String              @default("public") @map("discovery_mode")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  disabledAt        DateTime?           @map("disabled_at")
  deviceSessions    DeviceSession[]
  conversations     Conversation[]      @relation("ConversationCreator")
  memberships       ConversationMember[]
  friendRequestsSent     FriendRequest[] @relation("FriendRequestRequester")
  friendRequestsReceived FriendRequest[] @relation("FriendRequestAddressee")
  friendshipsAsUserA     Friendship[]    @relation("FriendshipUserA")
  friendshipsAsUserB     Friendship[]    @relation("FriendshipUserB")
  messages          Message[]
  mediaUploads      MediaAttachment[]
  pushRegistrations PushRegistration[]
  readCursors       ReadCursor[]
  reportsFiled      ModerationReport[] @relation("ModerationReportReporter")
  adminAuditLogs    AdminAuditLog[] @relation("AdminAuditLogActor")

  @@map("users")
}

model FriendRequest {
  id          String   @id @default(uuid())
  requesterId String   @map("requester_id")
  addresseeId String   @map("addressee_id")
  status      String   @default("pending")
  message     String?
  rejectReason String? @map("reject_reason")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  respondedAt DateTime? @map("responded_at")
  ignoredByAddresseeAt DateTime? @map("ignored_by_addressee_at")
  hiddenByRequesterAt DateTime? @map("hidden_by_requester_at")
  hiddenByAddresseeAt DateTime? @map("hidden_by_addressee_at")
  requester   User     @relation("FriendRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee   User     @relation("FriendRequestAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@index([requesterId, status, createdAt])
  @@index([addresseeId, status, createdAt])
  @@index([requesterId, addresseeId, status])
  @@map("friend_requests")
}

model Friendship {
  id        String   @id @default(uuid())
  userAId   String   @map("user_a_id")
  userBId   String   @map("user_b_id")
  hiddenByUserAAt DateTime? @map("hidden_by_user_a_at")
  hiddenByUserBAt DateTime? @map("hidden_by_user_b_at")
  createdAt DateTime @default(now()) @map("created_at")
  userA     User     @relation("FriendshipUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User     @relation("FriendshipUserB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId, createdAt])
  @@index([userBId, createdAt])
  @@map("friendships")
}

model VerificationCode {
  identifier String
  purpose    String
  code       String
  createdAt  DateTime  @default(now()) @map("created_at")
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")

  @@id([identifier, purpose])
  @@map("verification_codes")
}

model DeviceSession {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  deviceName   String    @map("device_name")
  refreshNonce String    @map("refresh_nonce")
  createdAt    DateTime  @default(now()) @map("created_at")
  lastSeenAt   DateTime  @default(now()) @map("last_seen_at")
  revokedAt    DateTime? @map("revoked_at")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  pushRegistrations PushRegistration[]

  @@index([userId, revokedAt, lastSeenAt])
  @@map("device_sessions")
}

model Conversation {
  id             String               @id @default(uuid())
  type           String
  title          String?
  createdBy      String               @map("created_by")
  directKey      String?              @unique @map("direct_key")
  latestSequence Int                  @default(0) @map("latest_sequence")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  creator        User                 @relation("ConversationCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  attachments    MediaAttachment[]
  members        ConversationMember[]
  messages       Message[]
  readCursors    ReadCursor[]

  @@index([createdBy, updatedAt])
  @@index([updatedAt])
  @@map("conversations")
}

model ConversationMember {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  userId         String       @map("user_id")
  role           String
  joinedAt       DateTime     @default(now()) @map("joined_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, joinedAt])
  @@map("conversation_members")
}

model Message {
  id              String       @id @default(uuid())
  conversationId  String       @map("conversation_id")
  senderId        String       @map("sender_id")
  clientMessageId String       @map("client_message_id")
  type            String
  status          String
  sequence        Int
  content         Json
  failureReason   String?      @map("failure_reason")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@unique([conversationId, sequence])
  @@unique([conversationId, senderId, clientMessageId])
  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
  @@map("messages")
}

model ReadCursor {
  id               String       @id @default(uuid())
  conversationId   String       @map("conversation_id")
  userId           String       @map("user_id")
  lastReadSequence Int          @default(0) @map("last_read_sequence")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, updatedAt])
  @@map("read_cursors")
}

model MediaAttachment {
  id             String       @id @default(uuid())
  ownerId        String       @map("owner_id")
  conversationId String       @map("conversation_id")
  purpose        String
  attachmentKind String       @map("attachment_kind")
  status         String       @default("pending_upload")
  objectKey      String       @unique @map("object_key")
  fileName       String       @map("file_name")
  mimeType       String       @map("mime_type")
  sizeBytes      Int          @map("size_bytes")
  previewObjectKey String?    @map("preview_object_key")
  failureReason  String?      @map("failure_reason")
  uploadedAt     DateTime?    @map("uploaded_at")
  confirmedAt    DateTime?    @map("confirmed_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  owner          User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, status, createdAt])
  @@index([ownerId, createdAt])
  @@map("media_attachments")
}

model PushRegistration {
  id               String        @id @default(uuid())
  userId           String        @map("user_id")
  sessionId        String        @map("session_id")
  provider         String
  token            String
  pushEnvironment  String        @map("push_environment")
  privacyModeEnabled Boolean     @default(false) @map("privacy_mode_enabled")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  lastRegisteredAt DateTime      @default(now()) @map("last_registered_at")
  revokedAt        DateTime?     @map("revoked_at")
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  session          DeviceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([provider, token])
  @@index([sessionId, provider, revokedAt])
  @@index([userId, revokedAt, updatedAt])
  @@map("push_registrations")
}

model ModerationReport {
  id               String   @id @default(uuid())
  reporterId       String   @map("reporter_id")
  targetType       String   @map("target_type")
  targetId         String   @map("target_id")
  conversationId   String?  @map("conversation_id")
  messageId        String?  @map("message_id")
  reportedUserId   String?  @map("reported_user_id")
  reasonCode       String   @map("reason_code")
  description      String?  @map("description")
  status           String   @default("pending_review")
  resolutionNote   String?  @map("resolution_note")
  handledByUserId  String?  @map("handled_by_user_id")
  handledAt        DateTime? @map("handled_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  reporter         User     @relation("ModerationReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([reporterId, createdAt])
  @@index([targetType, targetId, status])
  @@index([status, createdAt])
  @@map("moderation_reports")
}

model AdminAuditLog {
  id             String    @id @default(uuid())
  actorUserId    String?   @map("actor_user_id")
  action         String
  targetType     String    @map("target_type")
  targetId       String    @map("target_id")
  result         String
  summary        String    @map("summary")
  metadata       Json?     @map("metadata")
  createdAt      DateTime  @default(now()) @map("created_at")
  actor          User?     @relation("AdminAuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId, createdAt])
  @@map("admin_audit_logs")
}
